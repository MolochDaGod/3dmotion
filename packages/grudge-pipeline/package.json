{
  "name": "@grudgestudio/pipeline",
  "version": "1.0.0",
  "description": "Grudge Pipeline — Meshy AI Studio components, hooks, types, and Zustand store for generating, texturing, remeshing, and auto-rigging 3D game characters.",
  "keywords": ["meshy", "3d", "ai", "rigging", "game", "react", "pipeline"],
  "author": "MolochDaGod",
  "license": "MIT",
  "homepage": "https://github.com/MolochDaGod/GrudgeStudioNPM#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MolochDaGod/GrudgeStudioNPM.git"
  },
  "bugs": {
    "url": "https://github.com/MolochDaGod/GrudgeStudioNPM/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationDir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "framer-motion": ">=10.0.0",
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zustand": ">=4.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
